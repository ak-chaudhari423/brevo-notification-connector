{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Brevo Notification Connector",
  "id": "io.camunda.connector.brevotemplate.v1",
  "version": 8,
  "description": "Send Email / SMS / WhatsApp via Brevo Notification Connector",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "notification",
      "label": "Notification Details"
    },
    {
      "id": "output",
      "label": "Output mapping"
    },
    {
      "id": "error",
      "label": "Error handling"
    },
    {
      "id": "retries",
      "label": "Retries"
    }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "brevo-notification-connector",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      }
    },
    {
      "label": "API Key",
      "type": "String",
      "group": "authentication",
      "feel": "optional",
      "binding": {
        "type": "zeebe:input",
        "name": "apiKey"
      },
      "constraints": {
        "notEmpty": true
      },
      "description": "Brevo API Key"
    },
    {
      "id": "notification.notificationType",
      "label": "Notification Type",
      "type": "Dropdown",
      "group": "notification",
      "value": "email",
      "constraints": {
        "notEmpty": true
      },
      "binding": {
        "type": "zeebe:input",
        "name": "notificationType"
      },
      "choices": [
        {
          "name": "Email",
          "value": "email"
        },
        {
          "name": "SMS",
          "value": "sms"
        },
        {
          "name": "WhatsApp",
          "value": "whatsapp"
        }
      ]
    },
    {
      "id": "notification.email",
      "label": "Email Sender Address",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "sender"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "email"
      }
    },
    {
      "id": "notification.email",
      "label": "Email Receiver Address",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "receiver"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "email"
      }
    },
    {
      "id": "notification.phone",
      "label": "Phone sender Number",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "sender"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "sms"
      }
    },
    {
      "id": "notification.phone",
      "label": "Phone Receiver Number",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "receiver"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "sms"
      }
    },
    {
      "id": "notification.phoneWhatsapp",
      "label": "WhatsApp Sender Number",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "sender"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "whatsapp"
      }
    },
    {
      "id": "notification.phoneWhatsapp",
      "label": "WhatsApp Receiver Number",
      "type": "String",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "receiver"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "whatsapp"
      }
    },
    {
      "id": "notification.message",
      "label": "Message Body",
      "type": "Text",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "messageBody"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "oneOf": [
          "sms",
          "whatsapp"
        ]
      }
    },
    {
      "id": "notification.htmlMessage",
      "label": "HTML Email Body",
      "type": "Text",
      "feel": "optional",
      "group": "notification",
      "binding": {
        "type": "zeebe:input",
        "name": "messageBody"
      },
      "constraints": {
        "notEmpty": true
      },
      "condition": {
        "property": "notification.notificationType",
        "equals": "email"
      }
    },
    {
      "label": "Result Variable",
      "description": "Process variable to store response",
      "type": "String",
      "group": "output",
      "value": "notificationResult",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      }
    },
    {
      "label": "Result Expression",
      "description": "Expression to map the response into process variables",
      "type": "Text",
      "group": "output",
      "feel": "required",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultExpression"
      }
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">documentation</a>.",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/jpeg;base64,"
  }
}